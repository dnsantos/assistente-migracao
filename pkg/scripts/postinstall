#!/bin/bash
set -euo pipefail
##
## postinstall
##
## Executed automatically by macOS after the PKG is installed.
## Responsibilities:
##   1. Set correct permissions on scripts and LaunchDaemon plist
##   2. Inject the Intune client_secret into the System Keychain
##   3. Register and start the LaunchDaemon (which runs the migration)
##
## ── IMPORTANT ─────────────────────────────────────────────────────────────────
## The client_secret below must be rotated before each deployment.
## Never commit the real secret to the repository — use a placeholder here
## and inject the actual value through your secrets management pipeline
## (Jamf parameter, CI/CD variable, etc.) before building the PKG.
##
## WHEN CUSTOMIZING THIS FILE:
##   COMPANY_NAME  → must match bin/config.sh
##   PLIST_NAME    → must match the Label in pkg/LaunchDaemon/*.plist
##   KEYCHAIN_*    → must match bin/config.sh
## ─────────────────────────────────────────────────────────────────────────────

# ── CONFIGURATION ─────────────────────────────────────────────────────────────
readonly COMPANY_NAME="ACME"                                          # <── match bin/config.sh
readonly BASE_DIR="/Library/Application Support/${COMPANY_NAME} MDM Migration"
readonly PLIST_NAME="com.acme.mdm-migration"                          # <── match plist Label
readonly PLIST_PATH="/Library/LaunchDaemons/${PLIST_NAME}.plist"

# Intune App Registration — client_secret
# Replace with your actual secret (or inject via CI/CD pipeline)
INTUNE_SECRET="YOUR_CLIENT_SECRET_HERE"                               # <── change this

# Keychain identifiers — must match bin/config.sh
readonly KEYCHAIN_SERVICE="MDMMigrationService"                       # <── match bin/config.sh
readonly KEYCHAIN_ACCOUNT="IntuneAuth"                                # <── match bin/config.sh
# ──────────────────────────────────────────────────────────────────────────────

echo "[postinstall] Starting post-installation..."

###############################################################################
# STEP 1 — Set permissions on LaunchDaemon plist
###############################################################################
echo "[postinstall] Setting permissions on LaunchDaemon plist..."
chmod 644 "${PLIST_PATH}"
chown root:wheel "${PLIST_PATH}"
echo "[postinstall] ✓ Plist permissions set"

###############################################################################
# STEP 2 — Set execute permissions on all scripts and jq binaries
###############################################################################
echo "[postinstall] Setting execute permissions on scripts..."
chmod +x "${BASE_DIR}/bin/"*.sh
[[ -f "${BASE_DIR}/bin/jq-macos-arm64" ]] && chmod +x "${BASE_DIR}/bin/jq-macos-arm64"
[[ -f "${BASE_DIR}/bin/jq-macos-amd64" ]] && chmod +x "${BASE_DIR}/bin/jq-macos-amd64"
echo "[postinstall] ✓ Permissions set"

###############################################################################
# STEP 3 — Inject client_secret into System Keychain
###############################################################################
echo "[postinstall] Injecting Intune credentials into System Keychain..."

# Preventive cleanup to avoid duplicate entries
/usr/bin/security delete-generic-password \
    -s "${KEYCHAIN_SERVICE}" \
    -a "${KEYCHAIN_ACCOUNT}" \
    /Library/Keychains/System.keychain 2>/dev/null || true

# Store the secret
if ! /usr/bin/security add-generic-password \
    -a "${KEYCHAIN_ACCOUNT}" \
    -s "${KEYCHAIN_SERVICE}" \
    -w "${INTUNE_SECRET}" \
    -T "/usr/bin/security" \
    /Library/Keychains/System.keychain; then
    echo "[postinstall] ✗ Failed to store credentials" >&2
    exit 1
fi
echo "[postinstall] ✓ Credentials stored in System Keychain"

###############################################################################
# STEP 4 — Register and start the LaunchDaemon
###############################################################################
echo "[postinstall] Registering LaunchDaemon..."

# Unload first in case a previous version is running
/bin/launchctl bootout system "${PLIST_PATH}" 2>/dev/null || true

# Bootstrap (register + start) — RunAtLoad=true will execute the migration
if ! /bin/launchctl bootstrap system "${PLIST_PATH}"; then
    echo "[postinstall] ✗ Failed to register LaunchDaemon" >&2
    exit 1
fi
echo "[postinstall] ✓ LaunchDaemon registered and started"

echo "[postinstall] ✓ Post-installation complete"
# macOS deletes this script automatically after installation
exit 0
